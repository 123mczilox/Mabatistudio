# Copy this file to .env and fill in the values before deploying.
# Do NOT commit .env to version control.

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace_with_generated_secret_key
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DJANGO_ALLOWED_HOSTS=mabati-hub-kenya.onrender.com,www.mabatihubkenya.co.ke,mabatihubkenya.co.ke
CSRF_TRUSTED_ORIGINS=https://mabati-hub-kenya.onrender.com,https://www.mabatihubkenya.co.ke,https://mabatihubkenya.co.ke

# Optional S3-compatible storage
DJANGO_USE_S3=False
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_STORAGE_BUCKET_NAME=product-images
AWS_S3_ENDPOINT_URL=your_s3_endpoint_url_here
AWS_S3_REGION_NAME=eu-west-1

# Optional Supabase storage
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_service_role_key_here
SUPABASE_BUCKET_NAME=product-images
